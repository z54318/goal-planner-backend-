# 应用运行环境。
APP_ENV=dev
# API 服务监听地址。
HTTP_ADDR=:8080
# worker 日志中显示的进程名称。
WORKER_NAME=ai-worker

# API 和 worker 共用的 MySQL 连接串。
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/goal_planner?charset=utf8mb4&parseTime=True&loc=Local
# Redis 地址，后续可用于缓存和异步任务。
REDIS_ADDR=127.0.0.1:6379
# JWT 签名密钥。
JWT_SECRET=change-me
# AI 服务提供商的接口密钥。使用 Ollama 本地模式时可填任意非空值。
AI_API_KEY=sk-izskzazgcddwkoofoyqilzadcmjohgtcshioqntawddjtrdf
# AI 服务基础地址，默认使用本地 Ollama 的 OpenAI 兼容接口。
AI_BASE_URL=https://api.siliconflow.com/v1
# AI 模型名称。
AI_MODEL=Qwen/Qwen3-VL-32B-Instruct
