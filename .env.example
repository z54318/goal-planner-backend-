# 应用运行环境。
APP_ENV=dev
# API 服务监听地址。
HTTP_ADDR=:8080
# worker 日志中显示的进程名称。
WORKER_NAME=ai-worker

# API 和 worker 共用的 MySQL 连接串。
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/goal_planner?charset=utf8mb4&parseTime=True&loc=Local
# Redis 地址，后续可用于缓存和异步任务。
REDIS_ADDR=127.0.0.1:6379
# JWT 签名密钥。
JWT_SECRET=change-me
# AI 服务提供商的接口密钥。
AI_API_KEY=your-ai-api-key
